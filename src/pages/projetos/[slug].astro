---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { useTranslations } from '../../i18n/utils';

export async function getStaticPaths() {
  const all = await getCollection('projects', ({ data }) => data.locale === 'pt');
  return all.map((entry) => ({
    params: { slug: entry.id.replace(/^pt-/, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const t = useTranslations('pt');
const { title, summary, year, role, stack, client, url } = entry.data;
---
<Base title={title} description={summary}>
  <article class="pt-24 md:pt-32 pb-24">
    <div class="container-x">
      <a href="/#projects" class="text-sm text-muted mb-12 inline-block">← {t('projects.back')}</a>

      <header class="mb-16">
        <h1 class="font-display font-bold mb-6" style="font-size: var(--text-display-lg);">{title}</h1>
        <p class="text-lg md:text-xl text-muted max-w-2xl">{summary}</p>
      </header>

      <dl class="grid sm:grid-cols-2 md:grid-cols-4 gap-8 mb-16 pb-12 border-b border-fg/10">
        {client && (
          <div>
            <dt class="text-xs text-muted mb-1">{t('projects.client')}</dt>
            <dd>{client}</dd>
          </div>
        )}
        <div>
          <dt class="text-xs text-muted mb-1">{t('projects.role')}</dt>
          <dd>{role}</dd>
        </div>
        <div>
          <dt class="text-xs text-muted mb-1">{t('projects.year')}</dt>
          <dd>{year}</dd>
        </div>
        <div>
          <dt class="text-xs text-muted mb-1">{t('projects.stack')}</dt>
          <dd>{stack.join(', ')}</dd>
        </div>
      </dl>

      <div class="prose-elevia max-w-2xl">
        <Content />
      </div>

      {url && (
        <div class="mt-12">
          <a href={url} target="_blank" rel="noopener" class="btn btn-primary">{t('projects.viewCase')}</a>
        </div>
      )}
    </div>
  </article>
</Base>

<style is:global>
  .prose-elevia { font-size: 1.0625rem; line-height: 1.7; }
  .prose-elevia h2 { font-size: 1.5rem; font-weight: 600; margin-top: 2.5rem; margin-bottom: 0.75rem; }
  .prose-elevia h3 { font-size: 1.125rem; font-weight: 600; margin-top: 2rem; margin-bottom: 0.5rem; }
  .prose-elevia p { margin-bottom: 1rem; }
  .prose-elevia ul { list-style: disc; padding-left: 1.25rem; }
  .prose-elevia ul li { margin-bottom: 0.25rem; }
</style>
