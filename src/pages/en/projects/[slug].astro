---
import { getCollection, render } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import { useTranslations } from '../../../i18n/utils';

export async function getStaticPaths() {
  const all = await getCollection('projects', ({ data }) => data.locale === 'en');
  return all.map((entry) => ({
    params: { slug: entry.id.replace(/^en-/, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const t = useTranslations('en');
const { title, summary, year, role, stack, client, url, demo } = entry.data;
---
<Base title={title} description={summary}>
  <article class="pt-12 md:pt-24 pb-24">
    <div class="container-x">
      <a href="/en/#projects" class="inline-flex items-center gap-2 text-sm font-mono uppercase tracking-wider text-muted hover:text-fg transition-colors mb-10 md:mb-16">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        {t('projects.back')}
      </a>

      <header class="mb-16 md:mb-24">
        <p class="font-mono text-xs uppercase tracking-[0.2em] text-muted mb-6 flex items-center gap-3">
          <span class="inline-block w-8 h-px bg-fg/30"></span>
          {t('nav.projects')} · {year}
          {demo && <span class="px-2 py-0.5 rounded-full bg-accent/15 text-accent ml-1">{t('projects.demo')}</span>}
        </p>
        <h1 class="font-display font-extrabold mb-8" style="font-size: var(--text-display-lg); line-height: 0.95;">{title}</h1>
        <p class="text-xl md:text-2xl text-muted max-w-3xl leading-relaxed">{summary}</p>
      </header>

      <dl class="grid sm:grid-cols-2 md:grid-cols-4 gap-px bg-fg/10 border border-fg/10 mb-16 md:mb-24">
        {client && (
          <div class="bg-bg p-6">
            <dt class="font-mono text-[0.7rem] uppercase tracking-[0.2em] text-muted mb-2">{t('projects.client')}</dt>
            <dd class="font-display font-bold text-base">{client}</dd>
          </div>
        )}
        <div class="bg-bg p-6">
          <dt class="font-mono text-[0.7rem] uppercase tracking-[0.2em] text-muted mb-2">{t('projects.role')}</dt>
          <dd class="font-display font-bold text-base">{role}</dd>
        </div>
        <div class="bg-bg p-6">
          <dt class="font-mono text-[0.7rem] uppercase tracking-[0.2em] text-muted mb-2">{t('projects.year')}</dt>
          <dd class="font-display font-bold text-base">{year}</dd>
        </div>
        <div class="bg-bg p-6">
          <dt class="font-mono text-[0.7rem] uppercase tracking-[0.2em] text-muted mb-2">{t('projects.stack')}</dt>
          <dd class="font-display font-bold text-base">{stack.join(' · ')}</dd>
        </div>
      </dl>

      <div class="prose-elevia max-w-3xl mx-auto">
        <Content />
      </div>

      {url && (
        <div class="mt-16 text-center">
          <a href={url} target="_blank" rel="noopener" class="btn btn-primary">
            {t('projects.viewCase')}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M7 17L17 7M9 7h8v8"/></svg>
          </a>
        </div>
      )}
    </div>
  </article>
</Base>
