---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---
<section id="about" class="py-24 md:py-36 scroll-mt-20">
  <div class="container-x grid md:grid-cols-12 gap-10">
    <div class="md:col-span-5">
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-muted mb-4 flex items-center gap-3">
        <span class="inline-block w-8 h-px bg-fg/30"></span>
        {t('about.eyebrow')}
      </p>
      <h2 class="font-display font-extrabold" style="font-size: var(--text-display-md);">{t('about.title')}</h2>
    </div>
    <div class="md:col-span-7 md:pt-4">
      <p class="text-xl md:text-2xl leading-relaxed text-fg">{t('about.body')}</p>
    </div>
  </div>
</section>
