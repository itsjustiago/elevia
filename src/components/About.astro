---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---
<section id="about" class="py-24 md:py-32 scroll-mt-12">
  <div class="container-x">
    <h2 class="font-display font-bold mb-8" style="font-size: var(--text-display-md);">
      {t('about.title')}
    </h2>
    <p class="text-lg md:text-xl max-w-2xl text-fg">{t('about.body')}</p>
  </div>
</section>
