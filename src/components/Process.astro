---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const steps = [
  { titleKey: 'process.step1.title', descKey: 'process.step1.desc' },
  { titleKey: 'process.step2.title', descKey: 'process.step2.desc' },
  { titleKey: 'process.step3.title', descKey: 'process.step3.desc' },
  { titleKey: 'process.step4.title', descKey: 'process.step4.desc' },
] as const;
---
<section id="process" class="py-24 md:py-32 scroll-mt-12">
  <div class="container-x">
    <h2 class="font-display font-bold mb-16" style="font-size: var(--text-display-lg);">
      {t('process.title')}
    </h2>

    <ol class="grid md:grid-cols-2 gap-12 md:gap-16">
      {steps.map((s) => (
        <li>
          <h3 class="font-display font-semibold mb-3 text-2xl md:text-3xl">{t(s.titleKey as any)}</h3>
          <p class="text-muted leading-relaxed max-w-md">{t(s.descKey as any)}</p>
        </li>
      ))}
    </ol>
  </div>
</section>
