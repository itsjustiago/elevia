---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const services = [
  { titleKey: 'services.web.title', descKey: 'services.web.desc' },
  { titleKey: 'services.webapp.title', descKey: 'services.webapp.desc' },
  { titleKey: 'services.mobile.title', descKey: 'services.mobile.desc' },
  { titleKey: 'services.it.title', descKey: 'services.it.desc' },
] as const;
---
<section id="services" class="py-24 md:py-32 scroll-mt-12">
  <div class="container-x">
    <h2 class="font-display font-bold mb-16" style="font-size: var(--text-display-lg);">
      {t('services.title')}
    </h2>

    <ul class="grid md:grid-cols-2 gap-12 md:gap-16">
      {services.map((s) => (
        <li>
          <h3 class="font-display font-semibold mb-3 text-2xl md:text-3xl">{t(s.titleKey as any)}</h3>
          <p class="text-muted leading-relaxed max-w-md">{t(s.descKey as any)}</p>
        </li>
      ))}
    </ul>
  </div>
</section>
