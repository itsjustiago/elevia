---
interface Props {
  slug: string;
  title: string;
  summary: string;
  year: string | number;
  href: string;
}

const { title, summary, year, href } = Astro.props;
---
<a href={href} class="block py-8 border-t border-fg/10 last:border-b">
  <div class="flex items-baseline justify-between gap-6">
    <h3 class="font-display font-semibold text-2xl md:text-3xl">{title}</h3>
    <span class="text-sm text-muted shrink-0">{year}</span>
  </div>
  <p class="mt-2 text-muted max-w-2xl">{summary}</p>
</a>
