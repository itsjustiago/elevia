---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---
<section class="pt-32 md:pt-40 pb-24 md:pb-32">
  <div class="container-x">
    <h1 class="font-display font-bold" style="font-size: var(--text-display-xl);">
      {t('hero.title.line1')} {t('hero.title.line2')} {t('hero.title.line3')} {t('hero.title.line4')}
    </h1>

    <p class="mt-10 text-lg md:text-xl text-muted max-w-xl">
      {t('hero.subtitle')}
    </p>

    <div class="mt-10 flex flex-wrap gap-3">
      <a href="#projects" class="btn btn-primary">{t('hero.cta.primary')}</a>
      <a href="#contact" class="btn btn-ghost">{t('hero.cta.secondary')}</a>
    </div>
  </div>
</section>
