---
import { getCollection } from 'astro:content';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import ProjectCard from './ProjectCard.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const all = await getCollection('projects', ({ data }) => data.locale === lang);
const projects = all.sort((a, b) => a.data.order - b.data.order);
---
<section id="projects" class="py-24 md:py-32 scroll-mt-12">
  <div class="container-x">
    <h2 class="font-display font-bold mb-12" style="font-size: var(--text-display-lg);">
      {t('projects.title')}
    </h2>

    <div>
      {projects.map((p) => {
        const cleanSlug = p.id.replace(/^(pt|en)-/, '');
        const href = lang === 'pt' ? `/projetos/${cleanSlug}` : `/en/projects/${cleanSlug}`;
        return (
          <ProjectCard
            slug={p.id}
            title={p.data.title}
            summary={p.data.summary}
            year={p.data.year}
            href={href}
          />
        );
      })}
    </div>
  </div>
</section>
